      "source": [
        "## Exercise 3\n",
        "We next implement functions to compute the tangency portfolio and the mean-variance efficient frontier for a given mean vector $\\mu$ and covariance matrix $\\Sigma$. The tangency portfolio maximizes the Sharpe ratio, while the efficient frontier contains the portfolios with minimum variance for a given target return."
      ],
      "id": "a3287bc5"
    },
    {
      "cell_type": "code",
      "metadata": {
        "cache": true
      },
      "source": [
        "#| label: ex3-frontier-functions\n",
        "\n",
        "def compute_tangency_portfolio(mu, Sigma):\n",
        "    inv_Sigma = np.linalg.inv(Sigma)\n",
        "\n",
        "    weights = inv_Sigma @ mu\n",
        "    weights = weights / np.sum(weights)\n",
        "\n",
        "    portfolio_mean = weights @ mu\n",
        "    portfolio_variance = weights @ Sigma @ weights\n",
        "    portfolio_volatility = np.sqrt(portfolio_variance)\n",
        "    portfolio_sharpe = portfolio_mean / portfolio_volatility\n",
        "\n",
        "    return {\n",
        "        \"weights\": weights,\n",
        "        \"mean\": portfolio_mean,\n",
        "        \"variance\": portfolio_variance,\n",
        "        \"volatility\": portfolio_volatility,\n",
        "        \"sharpe\": portfolio_sharpe\n",
        "    }\n",
        "\n",
        "\n",
        "def compute_efficient_frontier(mu, Sigma, n_points=100):\n",
        "    ones = np.ones(len(mu))\n",
        "    inv_Sigma = np.linalg.inv(Sigma)\n",
        "\n",
        "    A = ones @ inv_Sigma @ ones\n",
        "    B = ones @ inv_Sigma @ mu\n",
        "    C = mu @ inv_Sigma @ mu\n",
        "    D = A * C - B**2\n",
        "\n",
        "    target_returns = np.linspace(mu.min(), mu.max(), n_points)\n",
        "    frontier = []\n",
        "\n",
        "    for target_return in target_returns:\n",
        "        weights = inv_Sigma @ (\n",
        "            ((C - B * target_return) / D) * ones\n",
        "            + ((A * target_return - B) / D) * mu\n",
        "        )\n",
        "\n",
        "        portfolio_variance = weights @ Sigma @ weights\n",
        "        portfolio_volatility = np.sqrt(portfolio_variance)\n",
        "\n",
        "        frontier.append({\n",
        "            \"target_return\": target_return,\n",
        "            \"volatility\": portfolio_volatility,\n",
        "            \"variance\": portfolio_variance\n",
        "        })\n",
        "\n",
        "    return pd.DataFrame(frontier)"
      ],
      "id": "ex3-frontier-functions",
      "execution_count": null,
      "outputs": []
    },
