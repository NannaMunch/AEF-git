    "\n",
    "        mu_hat = simulated_returns.mean(axis=0)\n",
    "        Sigma_hat = np.cov(simulated_returns, rowvar=False, ddof=1)\n",
    "\n",
    "        strategy_weights = {\n",
    "            \"Equally weighted\": equal_weight_portfolio(n_assets),\n",
    "            \"Plug-in tangency\": compute_tangency_portfolio(mu_hat, Sigma_hat)[\"weights\"],\n",
    "            \"Global minimum variance\": compute_global_minimum_variance_portfolio(Sigma_hat),\n",
    "            \"Inverse volatility\": inverse_volatility_portfolio(Sigma_hat)\n",
    "        }\n",
    "\n",
    "        for strategy, weights in strategy_weights.items():\n",
    "            performance = evaluate_portfolio(weights, mu_true, Sigma_true)\n",
    "\n",
    "            results.append({\n",
    "                \"T\": T,\n",
    "                \"strategy\": strategy,\n",
    "                \"sharpe\": performance[\"sharpe\"]\n",
    "            })\n",
    "\n",
    "    return pd.DataFrame(results)"
