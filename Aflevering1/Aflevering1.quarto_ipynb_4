    "#| label: ex6-plugin-performance\n",
    "\n",
    "def simulate_plugin_tangency_performance(T, mu_true, Sigma_true, n_simulations=200):\n",
    "    true_tangency = compute_tangency_portfolio(mu_true, Sigma_true)\n",
    "\n",
    "    results = []\n",
    "\n",
    "    for simulation in range(n_simulations):\n",
    "        simulated_returns = simulate_returns(T, mu_true, Sigma_true)\n",
    "\n",
    "        mu_hat = simulated_returns.mean(axis=0)\n",
    "        Sigma_hat = np.cov(simulated_returns, rowvar=False, ddof=1)\n",
    "\n",
    "        plugin_tangency = compute_tangency_portfolio(mu_hat, Sigma_hat)\n",
    "\n",
    "        true_performance = evaluate_portfolio(true_tangency[\"weights\"], mu_true, Sigma_true)\n",
    "        plugin_performance = evaluate_portfolio(plugin_tangency[\"weights\"], mu_true, Sigma_true)\n",
    "\n",
    "        results.append({\n",
    "            \"T\": T,\n",
    "            \"true_sharpe\": true_performance[\"sharpe\"],\n",
    "            \"plugin_sharpe\": plugin_performance[\"sharpe\"]\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(results)"
   ]
