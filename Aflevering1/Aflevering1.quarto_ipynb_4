    "#| label: ex7-strategies\n",
    "\n",
    "def equal_weight_portfolio(n_assets):\n",
    "    return np.ones(n_assets) / n_assets\n",
    "\n",
    "\n",
    "def compute_global_minimum_variance_portfolio(Sigma):\n",
    "    ones = np.ones(Sigma.shape[0])\n",
    "    inv_Sigma = np.linalg.inv(Sigma)\n",
    "\n",
    "    weights = inv_Sigma @ ones\n",
    "    weights = weights / np.sum(weights)\n",
    "\n",
    "    return weights\n",
    "\n",
    "\n",
    "def inverse_volatility_portfolio(Sigma):\n",
    "    asset_volatility = np.sqrt(np.diag(Sigma))\n",
    "    inverse_volatility = 1 / asset_volatility\n",
    "    weights = inverse_volatility / np.sum(inverse_volatility)\n",
    "    return weights"
   ]
